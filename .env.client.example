# SocialAgent client config. Copy to ".env" next to docker-compose.client.yml.
#
#   cp .env.client.example .env   (Windows: copy .env.client.example .env)
#
# This file holds NO secrets - only which release to run. The user's own
# secrets (Anthropic API key, email login, social logins) are entered IN THE
# APP after first launch and stored encrypted in Docker volumes on this machine.

# Which release to run. Bump this (or use deploy/update.sh) to update;
# set it to an older value to roll back. Every published version stays in GHCR.
SOCIALAGENT_VERSION=0.2.1

# Where the images live. Lowercase. Change "gamergy" to your GHCR owner/org.
IMAGE_REPO=ghcr.io/gamergy

# PUBLIC URL of the app version manifest - powers the in-app "update available"
# prompt and "update.ps1 latest" / "Update SocialAgent.cmd". Safe if the page
# doesn't exist yet (the check silently disables itself). Blank = no check.
VERSION_MANIFEST_URL=https://raw.githubusercontent.com/Gamergy/socialagent-releases/main/latest.json

# Optional: PUBLIC URL of the local-model manifest (recommended-models.json).
# A private-repo raw URL will NOT work (404). Leave blank to just keep the
# pinned models current.
MODELS_MANIFEST_URL=

# ── Local AI models (optional) ──────────────────────────────────────────────
# "local-models" = download + run Ollama + the local models (~8 GB). Leave
# BLANK for a cloud-only install (Claude/OpenAI key) — skips that download,
# ideal for CPU-only laptops. The installer sets these; the dashboard Models
# page can switch a cloud install to local later.
COMPOSE_PROFILES=local-models
LOCAL_MODELS=1

# ── Host browser helper ─────────────────────────────────────────────────────
# The native companion app that drives the user's REAL Chrome for social
# login/posting (avoids container-browser bot detection). The installer sets
# HELPER_TOKEN to match the helper's config. Blank token = worker falls back to
# the in-container browser (fine for reading pages, not for social login).
HELPER_URL=http://host.docker.internal:8765
HELPER_TOKEN=
